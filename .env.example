# Exemplo de variáveis de ambiente para o projeto HydroSense (PostgreSQL)
# Copie este arquivo para .env e preencha com seus valores reais

# Banco de Dados PostgreSQL (containerizado no docker-compose)
POSTGRES_DB=hydrosense
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Datasource da aplicação (opcional — possui defaults no docker-compose)
# Para ambiente local fora do Compose, use localhost em vez de 'db'
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/hydrosense
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# Flyway
SPRING_FLYWAY_ENABLED=true

# JWT
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRATION=86400000

# JPA/Hibernate (opcional para desenvolvimento/local)
# Use 'update' temporariamente se o banco nao tiver sido migrado por Flyway
SPRING_JPA_DDL_AUTO=none
